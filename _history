ame":"main.blocks","patch":[{"start1":0,"length1":84,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"-292\" y=\"9\"></block></xml>"]]}]}]},{"timestamp":1778271912811,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"pxt.json","patch":[{"start1":496,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// tests go here; this will not be compiled when this package is used as an extension.\n"}]}],"snapshots":[{"timestamp":1778177049662,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <variables></variables>\n  <block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block>\n</xml>","main.ts":" ","README.md":" ","assets.json":"","pxt.json":"{\n    \"name\": \"skellyAI\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\"\n    ],\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1778184329186,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>","main.ts":"\n","README.md":" ","assets.json":"","skellyAI.ts":"/**\n * Custom blocks\n */\n//% weight=100 color=#c1b3b3 icon=\"☠\"\nnamespace skellyAI {\n    /**\n * runs skelly's happy animation.\n * @param skely describe parameter here, eg: skelly\n */\n    //% block=\"skelly happy $skely\"\n    //% weight=90\n    //% blockGap=8\n    export function happy(skely: Sprite): void {\n        let wordsToSpeak = null\n        let randomWordPicker = randint(1, 5)\n        if (randomWordPicker == 1) {\n            wordsToSpeak = word1\n        } else if (randomWordPicker == 2) {\n            wordsToSpeak = word2\n        } else if (randomWordPicker == 3) {\n            wordsToSpeak = word3\n        } else if (randomWordPicker == 4) {\n            wordsToSpeak = word4\n        } else if (randomWordPicker == 5) {\n            wordsToSpeak = word5\n        }\n        let skellyspeech = textsprite.create(\"\" + wordsToSpeak, 1, 15)\n        skellyspeech.setStayInScreen(true)\n        skellyspeech.setPosition(skely.x + 1, skely.y + 17)\n        skellyspeech.x += 2\n        let textlifespan = randint(2000, 4920)\n        skellyspeech.lifespan = textlifespan;\n        let textArrow = sprites.create(img`\n            . . 1 . .\n            . 1 1 1 .\n            1 1 1 1 1\n            . . . . .\n            . . . . .\n        `, SpriteKind.Player)\n        textArrow.setPosition(skely.x + 2, skely.y + 13)\n        textArrow.lifespan = textlifespan - 50\n        animation.runImageAnimation(skely, assets.animation`skellyTalk`, 250, false)\n    }\n\n    /**\n * runs skelly's think animation.\n * @param skely describe parameter here, eg: skelly\n */\n    //% block=\"think $skely\"\n    //% weight=80\n    //% blockGap=8\n    export function think(skely: Sprite): void {\n        animation.runImageAnimation(skely, assets.animation`skellyBlinkLong`, 592, false)\n        let skellythink = textsprite.create(\"hmm...\", -1, 0)\n        skellythink.setStayInScreen(true)\n        skellythink.setPosition(skely.x + 30, skely.y + 1)\n        skellythink.x += 2\n        let textlifespan = randint(2500, 2890)\n        skellythink.lifespan = textlifespan\n    }\n\n    /**\n * runs idle animations for skelly. if shouldCheckBehavior is set to true then it will also instead of idle animating, try to run other skelly actions. Actions include: happy, think, and the normal idle.\n * @param shouldCheckBehavior describe parameter here, eg: false\n * @param skely describe parameter here, eg: skelly\n */\n    //% block=\"idle $skely\"\n    //% weight=70\n    //% blockGap=8\n    export function idle(shouldCheckBehavior: Boolean, skely: Sprite): void {\n        if (!shouldCheckBehavior) {\n            animation.runImageAnimation(skely, assets.animation`skellyBlink`, 50, false)\n        } else {\n            if (Math.percentChance(10)) {\n                skellyAI.happy(skely)\n            } else if (Math.percentChance(70)) {\n                skellyAI.think(skely)\n            } else {\n                animation.runImageAnimation(skely, assets.animation`skellyBlink`, 50, false)\n            }\n        }\n    }\n\n    /**\n     * Summons Skelly. Only use this block once. Will place skelly in top left corner.\n     * @param distanceFromCorner describe parameter here, eg: 0\n     */\n    //% block=\"start skelly $distanceFromCorner\"\n    //% weight=60\n    //% blockGap=8\n    export function startskelly(distanceFromCorner: number): void {\n        //create skelly\n        let skelly = sprites.create(img`\n            ........................\n            ........................\n            ........................\n            ........................\n            ..........8888..........\n            ........88111188........\n            .......8b111111b8.......\n            .......8d11111118.......\n            ......8dd1111111d8......\n            ......8ddd111111d8......\n            ......8dddddd111d8......\n            ......8bddddbad1d8......\n            ......8cbbbdcaddb8......\n            .......8cbb111118.......\n            ........888881b18.......\n            ........8b118b8b8.......\n            ........88b11118........\n            ......8.888888b1........\n            ......8888888..b........\n            .......88888............\n            ........................\n            ........................\n            ........................\n            ........................\n        `, SpriteKind.Player)\n        skelly.setStayInScreen(true)\n        skelly.setPosition(1, 1)\n        let DistFromCorner = 7 + distanceFromCorner\n        skelly.x += DistFromCorner - 2;\n        skelly.y += DistFromCorner;\n        let hasbeencalculating = false\n        //skellyAI runs\n        game.onUpdateInterval(randint(5003,18500), function () {\n            if (hasbeencalculating) {\n                if (Math.percentChance(10)) {\n                    skellyAI.happy(skelly)\n                } else if (Math.percentChance(55)) {\n                    skellyAI.think(skelly)\n                } else {\n                    skellyAI.idle(false, skelly)\n                }\n            } else {\n                hasbeencalculating = true\n            }\n        })\n    }\n\n    /**\n    * sets skelly's happy speech options.\n    * @param skellyspeech1 describe parameter here, eg: \":)\"\n    * @param skellyspeech2 describe parameter here, eg: \"thx!\"\n    * @param skellyspeech3 describe parameter here, eg: \"yay!\"\n    * @param skellyspeech4 describe parameter here, eg: \"math!\"\n    * @param skellyspeech5 describe parameter here, eg: \"happy!\"\n    */\n    //% block=\"set skelly text\"\n    //% weight=50\n    //% blockGap=8\n    export function SkellyText(skellyspeech1: string, skellyspeech2: string, skellyspeech3: string, skellyspeech4: string, skellyspeech5: string,) {\n        if (!skellyspeech1 == null) {\n            word1 = skellyspeech1\n        }\n        if (!skellyspeech2 == null) {\n            word2 = skellyspeech2\n        }\n        if (!skellyspeech3 == null) {\n            word3 = skellyspeech3\n        }\n        if (!skellyspeech4 == null) {\n            word4 = skellyspeech4\n        }\n        if (!skellyspeech2 == null) {\n            word5 = skellyspeech5\n        }\n    }\n    export let word1 = \":)\";\n    export let word2 = \"thx!\"; \n    export let word3 = \"yay!\"; \n    export let word4 = \"I like math!\"; \n    export let word5 = \"me happy!\"\n}","images.g.jres":"{\n    \"anim1\": {\n        \"namespace\": \"myAnimations\",\n        \"id\": \"anim1\",\n        \"mimeType\": \"application/mkcd-animation\",\n        \"data\": \"\",\n        \"displayName\": \"skellyTalk\"\n    },\n    \"anim2\": {\n        \"namespace\": \"myAnimations\",\n        \"id\": \"anim2\",\n        \"mimeType\": \"application/mkcd-animation\",\n        \"data\": \"\",\n        \"displayName\": \"skellyBlink\"\n    },\n    \"anim3\": {\n        \"namespace\": \"myAnimations\",\n        \"id\": \"anim3\",\n        \"mimeType\": \"application/mkcd-animation\",\n        \"data\": \"\",\n        \"displayName\": \"skellyBlinkLong\"\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myImages\"\n    }\n}","images.g.ts":"","tilemap.g.jres":"{\n    \"transparency16\": {\n        \"data\": \"hwQQABAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA==\",\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"tilemapTile\": true\n    },\n    \"*\": {\n        \"mimeType\": \"image/x-mkcd-f4\",\n        \"dataEncoding\": \"base64\",\n        \"namespace\": \"myTiles\"\n    }\n}","tilemap.g.ts":"","pxt.json":"{\n    \"name\": \"skellyAI\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"device\": \"*\",\n        \"arcade-text\": \"github:microsoft/arcade-text#v1.3.0\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\",\n        \"assets.json\",\n        \"skellyAI.ts\",\n        \"images.g.jres\",\n        \"images.g.ts\",\n        \"tilemap.g.jres\",\n        \"tilemap.g.ts\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1778186160674,"editorVersion":"4.0.14","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"></block></xml>","main.ts":"skellyAI.startSkelly(0)\nskellyAI.skellyText(\":)\", \"thx!\", \"yay!\", \"☻\", \"happy!\")","README.md":" ","assets.json":"","skellyAI.ts":"/**\n * Custom blocks\n */\n//% weight=