n.runImageAnimation(skely, assets.animation`skellyBlink`, 50, false)\n        } else {\n            if (Math.percentChance(10)) {\n                skellyAI.happy(skely)\n            } else if (Math.percentChance(70)) {\n                skellyAI.think(skely)\n            } else {\n                animation.runImageAnimation(skely, assets.animation`skellyBlink`, 50, false)\n            }\n        }\n    }\n\n    /**\n     * Summons Skelly. Only use this block once. \n     * Will place skelly in top left corner.\n     * \n     * @param distanceFromCorner how far away from the corner skelly will spawn.\n     */\n    //% blockId=startSkelly\n    //% block=\"start skelly with $distanceFromCorner pixels from corner\"\n    //% weight=75\n    //% blockGap=8\n    //% help=skellyAI/start-skelly\n    //% group=\"Life\"\n    export function startSkelly(distanceFromCorner: number): void {\n        //create skelly\n        skelly = sprites.create(img`\n            ........................\n            ........................\n            ........................\n            ........................\n            ..........8888..........\n            ........88111188........\n            .......8b111111b8.......\n            .......8d11111118.......\n            ......8dd1111111d8......\n            ......8ddd111111d8......\n            ......8dddddd111d8......\n            ......8bddddbad1d8......\n            ......8cbbbdcaddb8......\n            .......8cbb111118.......\n            ........888881b18.......\n            ........8b118b8b8.......\n            ........88b11118........\n            ......8.888888b1........\n            ......8888888..b........\n            .......88888............\n            ........................\n            ........................\n            ........................\n            ........................\n        `, SpriteKind.Skelly)\n        skelly.setStayInScreen(true)\n        skelly.setPosition(1, 1)\n        let DistFromCorner = 7 + 